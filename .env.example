APP_ENV=local

# ---------------------------------------------------------------------
# Option 1: Cloud / single URL (used by Render, Railway, Heroku, Neon).
# When DATABASE_URL is set, the host/name/user/pass below are ignored.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
# ---------------------------------------------------------------------
# DATABASE_URL=

# ---------------------------------------------------------------------
# Option 2: Local PostgreSQL (XAMPP/dev machine).
# ---------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eserbisyo_hub
DB_USER=postgres
DB_PASS=

APP_URL=
